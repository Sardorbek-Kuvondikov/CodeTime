GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id

# SMTP — used to email a notification on each contact-form submission.
# For Gmail, SMTP_USER is your address and SMTP_PASS is a 16-char App Password
# (https://myaccount.google.com/apppasswords), NOT your normal login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
# Optional — where notifications are delivered. Defaults to SMTP_USER.
CONTACT_NOTIFICATION_TO=your-email@gmail.com
